{
  "name": "stream-resilience-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "fault-provider": "tsx src/server/index.ts",
    "resilience-runner": "tsx src/client/cli.ts run",
    "resilience:scenarios": "tsx src/client/cli.ts scenarios",
    "resilience:smoke": "tsx src/client/cli.ts smoke",
    "dev": "concurrently -n fault-provider \"npm:fault-provider\" \"tsx src/client/cli.ts help-text\"",
    "server": "npm run fault-provider",
    "client": "npm run resilience-runner --",
    "scenarios": "npm run resilience:scenarios",
    "smoke": "npm run resilience:smoke",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "commander": "^14.0.2",
    "concurrently": "^9.2.1",
    "fastify": "^5.6.2",
    "openai": "^6.10.0",
    "tsx": "^4.20.6",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
