{
  "name": "stream-resilience-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "fault-provider": "tsx src/server/index.ts",
    "resilience-runner": "tsx src/client/cli.ts run",
    "resilience:scenarios": "tsx src/client/cli.ts scenarios",
    "resilience:smoke": "tsx src/client/cli.ts smoke",
    "dev": "concurrently -n fault-provider \"npm:fault-provider\" \"tsx src/client/cli.ts help-text\"",
    "server": "npm run fault-provider",
    "client": "npm run resilience-runner --",
    "scenarios": "npm run resilience:scenarios",
    "smoke": "npm run resilience:smoke",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "desktop:dev": "concurrently -n renderer,electron \"vite --config vite.desktop.config.ts\" \"tsx src/desktop/launcher.ts\"",
    "desktop:build": "vite build --config vite.desktop.config.ts",
    "desktop:dist": "tsx scripts/build-desktop.ts",
    "desktop": "npm run desktop:dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "commander": "^14.0.2",
    "concurrently": "^9.2.1",
    "fastify": "^5.6.2",
    "lucide-react": "^1.21.0",
    "openai": "^6.10.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.20.6",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.13"
  }
}
